# Server Port
PORT=5000

# MongoDB URI (Replace with your Atlas connection string in production)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/majestic-maths?retryWrites=true&w=majority

# Secret key for JWT signatures
JWT_SECRET=super_secret_production_key_change_me

# Allowed Frontend URL for CORS (no trailing slash)
FRONTEND_URL=https://your-production-app.vercel.app
